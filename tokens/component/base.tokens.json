{
  "component": {
    "button": {
      "primary": {
        "background": {
          "$value": "{semantic.color.interactive.primary}",
          "$type": "color",
          "$description": "Background color for primary buttons"
        },
        "text": {
          "$value": "#ffffff",
          "$type": "color",
          "$description": "Text color for primary buttons"
        },
        "padding": {
          "$value": "{spacing.button-padding}",
          "$type": "dimension",
          "$description": "Responsive padding for primary buttons using clamp function"
        },
        "border-radius": {
          "$value": "0.375rem",
          "$type": "borderRadius",
          "$description": "Border radius for primary buttons"
        },
        "border": {
          "$value": "none",
          "$type": "border",
          "$description": "Border for primary buttons"
        }
      },
      "secondary": {
        "background": {
          "$value": "{semantic.color.interactive.secondary}",
          "$type": "color",
          "$description": "Background color for secondary buttons"
        },
        "text": {
          "$value": "#ffffff",
          "$type": "color",
          "$description": "Text color for secondary buttons"
        },
        "padding": {
          "$value": "{spacing.button-padding}",
          "$type": "dimension",
          "$description": "Responsive padding for secondary buttons using clamp function"
        },
        "border-radius": {
          "$value": "0.375rem",
          "$type": "borderRadius",
          "$description": "Border radius for secondary buttons"
        },
        "border": {
          "$value": "1px solid {color.warm-pink}",
          "$type": "border",
          "$description": "Border for secondary buttons"
        }
      }
    },
    "card": {
      "background": {
        "$value": "{semantic.color.background.default}",
        "$type": "color",
        "$description": "Background color for cards"
      },
      "padding": {
        "$value": "{spacing.lg}",
        "$type": "dimension",
        "$description": "Padding for cards"
      },
      "border-radius": {
        "$value": "0.5rem",
        "$type": "borderRadius",
        "$description": "Border radius for cards"
      },
      "shadow": {
        "$value": "0 4px 6px rgba(0, 0, 0, 0.1)",
        "$type": "shadow",
        "$description": "Shadow for cards"
      }
    },
    "input": {
      "background": {
        "$value": "{semantic.color.background.default}",
        "$type": "color",
        "$description": "Background color for input fields"
      },
      "text": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color",
        "$description": "Text color for input fields"
      },
      "border": {
        "$value": "1px solid #d1d5db",
        "$type": "border",
        "$description": "Border for input fields"
      },
      "border-radius": {
        "$value": "0.375rem",
        "$type": "borderRadius",
        "$description": "Border radius for input fields"
      },
      "padding": {
        "$value": "{spacing.sm}",
        "$type": "dimension",
        "$description": "Padding for input fields"
      }
    }
  }
}
