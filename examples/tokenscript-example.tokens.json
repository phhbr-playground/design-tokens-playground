{
  "color": {
    "primary": {
      "$value": "#ff6b35",
      "$type": "color",
      "$description": "Primary brand color"
    },
    "secondary": {
      "$value": "{color.primary}",
      "$type": "color",
      "$description": "Secondary color (references primary)"
    }
  },
  "spacing": {
    "base": {
      "$value": "1rem",
      "$type": "spacing",
      "$description": "Base spacing unit"
    },
    "large": {
      "$value": "{spacing.base} * 2",
      "$type": "spacing",
      "$description": "Large spacing (computed from base)"
    }
  }
}